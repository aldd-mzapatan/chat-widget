# Chat Bubble - Variables de entorno de ejemplo

# URL del webhook de n8n (REQUERIDO)
N8N_WEBHOOK_URL=https://n8n.com/webhook/chat-bubble

# Nombre del bot (opcional, default: Asistente)
BOT_NAME=Asistente

# Color primario del widget (opcional, formato hex)
PRIMARY_COLOR=#6366f1

# Posición del widget: 'right' o 'left'
WIDGET_POSITION=right

# Mensaje de bienvenida (opcional)
WELCOME_MESSAGE=¡Hola! ¿En qué te puedo ayudar hoy?

# Timeout en ms para las peticiones al webhook (opcional, default: 30000)
REQUEST_TIMEOUT=30000
